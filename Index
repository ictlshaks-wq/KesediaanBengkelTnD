            "Sarawak": ["Bintulu", "Kapit", "Kuching", "Limbang", "Miri", "Mukah", "Samarahan", "Sarikei", "Sibu", "Sri Aman"],
            "Selangor": ["Gombak", "Hulu Langat", "Hulu Selangor", "Klang", "Kuala Langat", "Kuala Selangor", "Petaling", "Sabak Bernam", "Sepang"],
            "Terengganu": ["Besut", "Dungun", "Hulu Terengganu", "Kemaman", "Kuala Nerus", "Kuala Terengganu", "Marang", "Setiu"],
            "WP Kuala Lumpur": ["Bangsar/Pudu", "Keramat", "Sentul"],
        };

        const senaraiBengkel = [
            { id: "b1", nama: "BENGKEL RBT 1 (STUDIO REKA BENTUK)" },
            { id: "b2", nama: "BENGKEL 2 (ELEKTRIK & ELEKTRONIK)" },
            { id: "b3", nama: "BENGKEL 3 (PERTANIAN)" },
            { id: "b4", nama: "BENGKEL 4 (BILIK MASAKAN)" },
            { id: "b5", nama: "BENGKEL 5 (PEMBUATAN)" },
            { id: "b6", nama: "MAKMAL / BILIK KOMPUTER" }
        ];

        // 4 Kriteria Utama
        const kriteriaSenarai = [
            { id: "fizikal", label: "Struktur Fizikal (Dinding/Bumbung)" },
            { id: "pendawaian", label: "Sistem Pendawaian Elektrik" },
            { id: "paip", label: "Sistem Paip / Perpaipan" },
            { id: "kelengkapan", label: "Peralatan & Kelengkapan" }
        ];

        // 6 Pilihan bagi setiap kriteria beserta warna khas
        const pilihanEnam = [
            { val: "Tidak Berkenaan", colorClass: "text-gray-500", bgActive: "bg-gray-500" },
            { val: "Selesa", colorClass: "text-green-600", bgActive: "bg-green-600" },
            { val: "Tidak Selesa", colorClass: "text-blue-800", bgActive: "bg-blue-800" },
            { val: "Kefungsian", colorClass: "text-[#a16207]", bgActive: "bg-[#a16207]" }, // yellow-700
            { val: "Sekuriti", colorClass: "text-orange-500", bgActive: "bg-orange-500" },
            { val: "Keselamatan", colorClass: "text-red-600", bgActive: "bg-red-600" }
        ];

        let dbSubmissions = [];
        let chart1 = null;
        let chart2 = null;
        let pendingModalAction = 'dashboard';

        // --- INISIALISASI UI ---
        
        document.addEventListener("DOMContentLoaded", () => {
            binaJadualBengkel();
            loadMockData(); 
            initFilters();
        });

        function initFilters() {
            const filterNegeri = document.getElementById("filterNegeri");
            const pjdFilterNegeri = document.getElementById("pjdFilterNegeri");
            Object.keys(daerahMap).forEach(negeri => {
                filterNegeri.innerHTML += `<option value="${negeri}">${negeri}</option>`;
                pjdFilterNegeri.innerHTML += `<option value="${negeri}">${negeri}</option>`;
            });
        }

        function updatePjdFilterDaerah() {
            const negeri = document.getElementById("pjdFilterNegeri").value;
            const daerahSelect = document.getElementById("pjdFilterDaerah");
            daerahSelect.innerHTML = '<option value="">-- Semua Daerah --</option>';
            if (negeri && daerahMap[negeri]) {
                daerahSelect.disabled = false;
                daerahMap[negeri].forEach(d => {
                    daerahSelect.innerHTML += `<option value="${d}">${d}</option>`;
                });
            } else {
                daerahSelect.disabled = true;
            }
            muatSenaraiSekolahPjd();
        }

        function updateFilterDaerah() {
            const negeri = document.getElementById("filterNegeri").value;
            const daerahSelect = document.getElementById("filterDaerah");
            daerahSelect.innerHTML = '<option value="">Semua Daerah</option>';
            if (negeri && daerahMap[negeri]) {
                daerahSelect.disabled = false;
                daerahMap[negeri].forEach(d => {
                    daerahSelect.innerHTML += `<option value="${d}">${d}</option>`;
                });
            } else {
                daerahSelect.disabled = true;
            }
            applyFilters();
        }

        function updateDaerah() {
            const negeri = document.getElementById("negeri").value;
            const daerahSelect = document.getElementById("daerah");
            daerahSelect.innerHTML = '<option value="">-- Pilih Daerah --</option>';
            if (negeri && daerahMap[negeri]) {
                daerahSelect.disabled = false;
                daerahMap[negeri].forEach(d => {
                    daerahSelect.innerHTML += `<option value="${d}">${d}</option>`;
                });
            } else {
                daerahSelect.disabled = true;
            }
        }

        function binaJadualBengkel() {
            const container = document.getElementById("bengkel-container");
            let html = "";

            senaraiBengkel.forEach((bengkel, i) => {
                html += `
                <div class="mb-8">
                    <h4 class="font-bold text-gray-800 mb-2 border-l-4 border-primary pl-3">${i+1}. ${bengkel.nama}</h4>
                    <div class="overflow-x-auto shadow-sm rounded-t-lg">
                        <table class="w-full text-sm form-table bg-white text-center">
                            <thead>
                                <tr>
                                    <th colspan="8" class="bg-tblheader text-white font-bold py-2 uppercase tracking-wider">Keadaan Fizikal</th>
                                </tr>
                            </thead>
                            <tbody>
                `;

                kriteriaSenarai.forEach(kriteria => {
                    html += `<tr>
                        <td class="w-1/5 bg-tblleft text-amber-900 font-bold uppercase p-3 text-left">${kriteria.label}</td>
                    `;
                    
                    pilihanEnam.forEach(opt => {
                        html += `
                        <td class="p-1 min-w-[120px]">
                            <button type="button" 
                                onclick="pilihKriteria(this, '${bengkel.id}', '${kriteria.id}', '${opt.val}', '${opt.bgActive}', '${opt.colorClass}')" 
                                class="w-full py-2 px-1 font-semibold border border-gray-200 bg-white ${opt.colorClass} hover:bg-gray-50 transition rounded-sm btn-kriteria-${bengkel.id}-${kriteria.id}"
                                data-label="${opt.val}" data-color="${opt.colorClass}" data-bg="${opt.bgActive}">
                                ${opt.val}
                            </button>
                        </td>`;
                    });

                    // Ruangan Muat Naik Gambar
                    html += `
                        <td class="p-2 w-[60px] bg-gray-50">
                            <input type="hidden" id="input_${bengkel.id}_${kriteria.id}" required>
                            <input type="file" id="img_${bengkel.id}_${kriteria.id}" accept="image/*" onchange="gambarDipilih(this, 'btn_img_${bengkel.id}_${kriteria.id}')">
                            <button type="button" id="btn_img_${bengkel.id}_${kriteria.id}" onclick="document.getElementById('img_${bengkel.id}_${kriteria.id}').click()" class="bg-[#4a5568] hover:bg-gray-700 text-white p-2 rounded transition w-full flex justify-center items-center h-full">
                                <i class="fa-solid fa-image"></i>
                            </button>
                        </td>
                    </tr>`;
                });

                html += `</tbody></table></div></div>`;
            });

            container.innerHTML = html;
        }

        // --- FUNGSI INTERAKSI BUTTON ---

        function pilihKriteria(btnEl, bengkelId, kriteriaId, nilai, bgActive, colorClass) {
            const groupBtns = document.querySelectorAll(`.btn-kriteria-${bengkelId}-${kriteriaId}`);
            groupBtns.forEach(b => {
                b.classList.remove('text-white', b.dataset.bg);
                b.classList.add('bg-white', b.dataset.color);
                b.innerHTML = b.dataset.label; 
            });

            btnEl.classList.remove('bg-white', colorClass);
            btnEl.classList.add('text-white', bgActive);
            btnEl.innerHTML = `<i class="fa-solid fa-check mr-1"></i> ${nilai}`;
            document.getElementById(`input_${bengkelId}_${kriteriaId}`).value = nilai;
        }

        function selectPjdStatus(btnEl, inputId, bgActiveClass) {
            const group = btnEl.parentElement.querySelectorAll('button');
            group.forEach(b => {
                b.classList.remove('text-white', b.dataset.activeBg);
                b.classList.add('bg-white');
                b.classList.forEach(c => {
                    if(c.startsWith('text-') && c !== 'text-white') b.dataset.textColor = c;
                });
                b.innerHTML = b.dataset.val;
            });

            const originalTextColor = Array.from(btnEl.classList).find(c => c.startsWith('text-'));
            btnEl.dataset.activeBg = bgActiveClass;
            btnEl.classList.remove('bg-white');
            if(originalTextColor) btnEl.classList.remove(originalTextColor);
            btnEl.classList.add('text-white', bgActiveClass);
            btnEl.innerHTML = `<i class="fa-solid fa-check mr-1"></i> ${btnEl.dataset.val}`;

            document.getElementById(inputId).value = btnEl.dataset.val;
        }

        function gambarDipilih(inputEl, btnId) {
            const btn = document.getElementById(btnId);
            if (inputEl.files && inputEl.files[0]) {
                btn.classList.remove('bg-[#4a5568]', 'hover:bg-gray-700');
                btn.classList.add('bg-green-600', 'hover:bg-green-700');
                if(btnId === 'btn_jkr_upload') {
                    btn.innerHTML = `<i class="fa-solid fa-check-circle"></i> DIMUAT NAIK`;
                } else {
                    btn.innerHTML = `<i class="fa-solid fa-check"></i>`;
                }
            }
        }

        function getBadgeSpan(val) {
            const opt = pilihanEnam.find(p => p.val === val);
            if(!opt) return val;
            let bg = opt.bgActive;
            if(bg.includes('[')) { // untuk warna custom seperti hex
                return `<span class="px-2 py-1 rounded text-white text-[11px] block text-center mt-1" style="background-color: ${bg.replace('bg-[', '').replace(']', '')}">${val}</span>`;
            }
            return `<span class="px-2 py-1 rounded text-white text-[11px] block text-center mt-1 ${bg}">${val}</span>`;
        }

        // --- PENGHANTARAN BORANG (SEKOLAH & PJD) ---

        function submitFormSekolah(event) {
            event.preventDefault();

            let allFilled = true;
            senaraiBengkel.forEach(b => {
                kriteriaSenarai.forEach(k => {
                    if (!document.getElementById(`input_${b.id}_${k.id}`).value) allFilled = false;
                });
            });

            if (!allFilled) {
                alert("Sila lengkapkan pilihan untuk semua kriteria jadual Keadaan Fizikal.");
                return;
            }

            let jumlahKeselamatan = 0;
            let maklumatBengkel = [];

            senaraiBengkel.forEach(bengkel => {
                let pen = {};
                kriteriaSenarai.forEach(k => {
                    const val = document.getElementById(`input_${bengkel.id}_${k.id}`).value;
                    pen[k.id] = val;
                    if(val === "Keselamatan") jumlahKeselamatan++;
                });
                maklumatBengkel.push({ id: bengkel.id, penilaian: pen });
            });

            const dataObj = {
                id: Date.now(),
                tarikh: new Date().toLocaleDateString('ms-MY'),
                sekolah: { 
                    negeri: document.getElementById("negeri").value, 
                    daerah: document.getElementById("daerah").value, 
                    nama: document.getElementById("namaSekolah").value.toUpperCase(),
                    namaPegawai: document.getElementById("sekolahNamaPegawai").value,
                    jawatanPegawai: document.getElementById("sekolahJawatanPegawai").value
                },
                bengkel: maklumatBengkel,
                isuKeselamatan: jumlahKeselamatan,
                pjd: null // PJD belum isi
            };

            dbSubmissions.unshift(dataObj);
            
            document.getElementById("msgModalTitle").innerText = "Pengisian Berjaya!";
            document.getElementById("msgModalDesc").innerText = "Maklumat sekolah telah direkodkan dan kini dalam status 'Menunggu Pengesahan PJD'.";
            document.getElementById("btnModalClose").innerText = "OK";
            pendingModalAction = 'form'; // stay and reload or just close
            showModal();
        }

        function submitFormPjd(event) {
            event.preventDefault();
            
            if(!document.getElementById("pjdStatusInfra").value || !document.getElementById("pjdSkala").value) {
                alert("Sila pilih Status Infrastruktur dan Skala.");
                return;
            }

            const idSekolah = parseInt(document.getElementById("pilihSekolahPjd").value);
            const index = dbSubmissions.findIndex(s => s.id === idSekolah);
            
            if(index !== -1) {
                dbSubmissions[index].pjd = {
                    nama: document.getElementById("pjdNama").value,
                    kp: document.getElementById("pjdKp").value,
                    jawatan: document.getElementById("pjdJawatan").value,
                    tarikhSah: document.getElementById("pjdTarikh").value,
                    infra: document.getElementById("pjdStatusInfra").value,
                    skala: document.getElementById("pjdSkala").value,
                    catatan: document.getElementById("pjdCatatan").value
                };
                
                document.getElementById("msgModalTitle").innerText = "Pengesahan Berjaya!";
                document.getElementById("msgModalDesc").innerText = "Pengesahan Pegawai Teknikal (PJD) telah dikemas kini ke dalam sistem.";
                document.getElementById("btnModalClose").innerText = "Lihat Dashboard";
                pendingModalAction = 'pjd_done';
                showModal();
            }
        }

        // --- PJD TAB LOGIC ---

        function muatSenaraiSekolahPjd() {
            const select = document.getElementById("pilihSekolahPjd");
            const fNegeri = document.getElementById("pjdFilterNegeri").value;
            const fDaerah = document.getElementById("pjdFilterDaerah").value;

            // Filter data submission
            let filteredSubs = dbSubmissions;
            if (fNegeri) filteredSubs = filteredSubs.filter(s => s.sekolah.negeri === fNegeri);
            if (fDaerah) filteredSubs = filteredSubs.filter(s => s.sekolah.daerah === fDaerah);

            const pendingList = filteredSubs.filter(s => s.pjd === null);
            const completedList = filteredSubs.filter(s => s.pjd !== null);
            
            select.innerHTML = '<option value="">-- Pilih Sekolah Untuk Disahkan --</option>';
            
            if(pendingList.length > 0) {
                pendingList.forEach(s => {
                    select.innerHTML += `<option value="${s.id}">${s.sekolah.nama} (${s.sekolah.daerah}) - Tkh Isi: ${s.tarikh}</option>`;
                });
            } else {
                select.innerHTML = '<option value="">-- Tiada Sekolah Menunggu Pengesahan --</option>';
            }

            // Summary UI
            const summaryBox = document.getElementById("pjdSummaryBox");
            if (fNegeri || fDaerah) {
                summaryBox.classList.remove("hidden");
                document.getElementById("pjdSummaryDaerahTxt").innerText = fDaerah ? fDaerah : fNegeri;
                
                let html = `<p class="mb-1">Terdapat <strong>${pendingList.length}</strong> buah sekolah yang belum disahkan, dan <strong>${completedList.length}</strong> buah sekolah telah selesai disahkan.</p>`;
                
                if (pendingList.length > 0) {
                    html += `<p class="mt-2 font-semibold">Senarai Menunggu Pengesahan:</p><ul class="list-disc pl-5 mt-1 text-xs space-y-1 font-medium">`;
                    pendingList.forEach(s => {
                        html += `<li>${s.sekolah.nama} (Tarikh Pengisian: ${s.tarikh})</li>`;
                    });
                    html += `</ul>`;
                }
                document.getElementById("pjdSummaryContent").innerHTML = html;
            } else {
                summaryBox.classList.add("hidden");
            }
            
            document.getElementById("paparanMaklumatSekolah").classList.add("hidden");
            document.getElementById("formPengesahanPjd").classList.add("hidden");
        }

        function paparMaklumatSekolahPjd() {
            const id = parseInt(document.getElementById("pilihSekolahPjd").value);
            if(!id) {
                document.getElementById("paparanMaklumatSekolah").classList.add("hidden");
                document.getElementById("formPengesahanPjd").classList.add("hidden");
                return;
            }

            const school = dbSubmissions.find(s => s.id === id);
            if(school) {
                document.getElementById("paparNamaSekolah").innerText = school.sekolah.nama;
                document.getElementById("paparLokasiSekolah").innerText = `${school.sekolah.daerah}, ${school.sekolah.negeri}`;
                document.getElementById("paparPengisiSekolah").innerText = `${school.sekolah.namaPegawai} (${school.sekolah.jawatanPegawai})`;
                document.getElementById("paparTarikhSekolah").innerText = school.tarikh;

                let jadualHtml = `<table class="w-full text-xs text-left border-collapse border border-gray-200">
                    <thead class="bg-gray-200 text-gray-700 uppercase"><tr>
                        <th class="border p-2">Bengkel</th><th class="border p-2 text-center">Fizikal</th><th class="border p-2 text-center">Pendawaian</th><th class="border p-2 text-center">Paip</th><th class="border p-2 text-center">Kelengkapan</th>
                    </tr></thead><tbody>`;
                
                school.bengkel.forEach(b => {
                    const findName = senaraiBengkel.find(x => x.id === b.id).nama;
                    jadualHtml += `<tr>
                        <td class="border p-2 font-semibold text-gray-700 bg-gray-50">${findName}</td>
                        <td class="border p-2 text-center align-middle">${getBadgeSpan(b.penilaian.fizikal)}</td>
                        <td class="border p-2 text-center align-middle">${getBadgeSpan(b.penilaian.pendawaian)}</td>
                        <td class="border p-2 text-center align-middle">${getBadgeSpan(b.penilaian.paip)}</td>
                        <td class="border p-2 text-center align-middle">${getBadgeSpan(b.penilaian.kelengkapan)}</td>
                    </tr>`;
                });
                jadualHtml += `</tbody></table>`;
                document.getElementById("paparJadualBengkel").innerHTML = jadualHtml;

                document.getElementById("paparanMaklumatSekolah").classList.remove("hidden");
                document.getElementById("formPengesahanPjd").classList.remove("hidden");
                
                document.getElementById("formPengesahanPjd").reset();
                
                // reset button status pjd
                document.querySelectorAll('.btn-pjd').forEach(b => {
                    b.classList.remove('text-white', b.dataset.activeBg);
                    b.classList.add('bg-white');
                    const ogText = Array.from(b.classList).find(c => c.startsWith('text-'));
                    if(ogText) b.dataset.textColor = ogText;
                    b.innerHTML = b.dataset.val;
                });
                document.getElementById("pjdStatusInfra").value = "";
                document.getElementById("pjdSkala").value = "";
                document.getElementById("pjdTarikh").value = new Date().toISOString().split('T')[0];
            }
        }

        // --- DASHBOARD & NAVIGATION LOGIC ---

        function switchPage(page) {
            document.getElementById("page-form").classList.toggle("hidden", page !== 'form');
            document.getElementById("page-pjd").classList.toggle("hidden", page !== 'pjd');
            document.getElementById("page-dashboard").classList.toggle("hidden", page !== 'dashboard');
            
            const inactiveClass = "text-gray-300 hover:bg-secondary hover:text-white px-4 py-2 rounded-md text-sm font-medium transition duration-200 flex items-center gap-2";
            const activeClass = "bg-secondary bg-opacity-50 hover:bg-opacity-100 text-white px-4 py-2 rounded-md text-sm font-medium transition duration-200 flex items-center gap-2";

            document.getElementById("btn-form").className = page === 'form' ? activeClass : inactiveClass;
            document.getElementById("btn-pjd").className = page === 'pjd' ? activeClass : inactiveClass;
            document.getElementById("btn-dashboard").className = page === 'dashboard' ? activeClass : inactiveClass;

            if(page === 'dashboard') refreshDashboard();
            if(page === 'pjd') muatSenaraiSekolahPjd();
        }

        function showModal() {
            const m = document.getElementById("successModal");
            const mc = document.getElementById("successModalContent");
            m.classList.remove("hidden");
            setTimeout(() => { m.classList.remove("opacity-0"); mc.classList.remove("scale-95"); }, 10);
        }

        function closeModal() {
            document.getElementById("successModal").classList.add("opacity-0");
            document.getElementById("successModalContent").classList.add("scale-95");
            setTimeout(() => {
                document.getElementById("successModal").classList.add("hidden");
                if(pendingModalAction === 'form') {
                    document.getElementById('bengkelForm').reset();
                    switchPage('pjd'); // suggest go to PJD after fill
                } else if(pendingModalAction === 'pjd_done') {
                    switchPage('dashboard');
                }
            }, 300);
        }

        let filteredData = [];

        function applyFilters() {
            const fNegeri = document.getElementById('filterNegeri').value;
            const fDaerah = document.getElementById('filterDaerah').value;
            const fSekolah = document.getElementById('filterSekolah').value.toUpperCase();
            const fStatus = document.getElementById('filterStatus').value;

            filteredData = dbSubmissions.filter(item => {
                let match = true;
                if (fNegeri && item.sekolah.negeri !== fNegeri) match = false;
                if (fDaerah && item.sekolah.daerah !== fDaerah) match = false;
                if (fSekolah && !item.sekolah.nama.includes(fSekolah)) match = false;
                
                if (fStatus) {
                    if (fStatus === "Menunggu PJD" && item.pjd !== null) match = false;
                    if (fStatus !== "Menunggu PJD") {
                        if (item.pjd === null) match = false;
                        else if (item.pjd.infra !== fStatus) match = false;
                    }
                }
                return match;
            });

            renderDashboardComponents(filteredData);
        }

        function resetFilters() {
            document.getElementById('filterNegeri').value = "";
            document.getElementById('filterDaerah').innerHTML = '<option value="">Semua Daerah</option>';
            document.getElementById('filterDaerah').disabled = true;
            document.getElementById('filterSekolah').value = "";
            document.getElementById('filterStatus').value = "";
            applyFilters();
        }

        function refreshDashboard() {
            applyFilters(); 
        }

        function renderDashboardComponents(dataToRender) {
            document.getElementById("kpi-total").innerText = dataToRender.length;
            
            let pendingCount = 0, infraSelamat = 0, infraLupus = 0;
            
            dataToRender.forEach(s => {
                if(s.pjd === null) {
                    pendingCount++;
                } else {
                    if(s.pjd.infra === "Selamat diduduki") infraSelamat++;
                    if(s.pjd.infra === "Lupus") infraLupus++;
                }
            });

            document.getElementById("kpi-pending").innerText = pendingCount;
            document.getElementById("kpi-approved").innerText = infraSelamat;
            document.getElementById("kpi-kiv").innerText = infraLupus;

            binaJadualDashboard(dataToRender);
            janaCarta(dataToRender);
        }

        function binaJadualDashboard(dataToRender) {
            const tbody = document.getElementById("tableBody");
            tbody.innerHTML = "";

            if(dataToRender.length === 0) {
                tbody.innerHTML = `<tr><td colspan="4" class="text-center p-8 text-gray-500">Tiada data direkodkan.</td></tr>`;
                return;
            }

            dataToRender.forEach((sub, i) => {
                let badgeClass = sub.isuKeselamatan > 0 ? "bg-red-600 text-white" : "bg-green-100 text-green-700";
                let textKeselamatan = sub.isuKeselamatan > 0 ? `${sub.isuKeselamatan} Isu` : "Tiada Isu";

                let pjdContent = "";

                if(sub.pjd === null) {
                    pjdContent = `
                        <span class="px-2 py-1 rounded text-xs font-bold bg-yellow-100 text-yellow-700 border border-yellow-200 inline-block mb-1">Menunggu PJD</span>
                        <div class="text-[10px] text-gray-500 uppercase">Tarikh Isi: ${sub.tarikh}</div>
                    `;
                } else {
                    let infraColor = "text-gray-800";
                    if(sub.pjd.infra === "Selamat diduduki") infraColor = "bg-teal-100 text-teal-700";
                    if(sub.pjd.infra === "Tidak selamat diduduki") infraColor = "bg-red-100 text-red-700";
                    if(sub.pjd.infra === "Dalam Penyelenggaraan") infraColor = "bg-gray-200 text-gray-700";
                    if(sub.pjd.infra === "Lupus") infraColor = "bg-red-900 text-white";

                    pjdContent = `
                        <div class="mb-1">
                            <span class="px-2 py-1 rounded text-xs font-bold ${infraColor}">${sub.pjd.infra}</span>
                        </div>
                        <div class="text-[11px] font-semibold text-gray-700 uppercase">${sub.pjd.skala}</div>
                        <div class="text-[10px] text-gray-500">Oleh: ${sub.pjd.nama} (${sub.pjd.tarikhSah})</div>
                    `;
                }

                tbody.innerHTML += `
                    <tr class="hover:bg-blue-50">
                        <td class="p-4 border-b align-top">${i + 1}</td>
                        <td class="p-4 border-b align-top">
                            <div class="font-bold text-primary">${sub.sekolah.nama}</div>
                            <div class="text-xs text-gray-500">${sub.sekolah.daerah}, ${sub.sekolah.negeri}</div>
                        </td>
                        <td class="p-4 border-b text-center align-top"><span class="px-2 py-1 text-xs font-bold rounded-full ${badgeClass}">${textKeselamatan}</span></td>
                        <td class="p-4 border-b align-top">
                            ${pjdContent}
                        </td>
                    </tr>
                `;
            });
        }

        function janaCarta(dataToRender) {
            // Count fizikal
            let dFizikal = { "Tidak Berkenaan":0, "Selesa":0, "Tidak Selesa":0, "Kefungsian":0, "Sekuriti":0, "Keselamatan":0 };
            dataToRender.forEach(sub => {
                sub.bengkel.forEach(b => {
                    Object.values(b.penilaian).forEach(val => { if(dFizikal[val] !== undefined) dFizikal[val]++; });
                });
            });

            // Count PJD (Abaikan yang null)
            let dPJD = { "Selamat":0, "T.Selamat":0, "Selenggara":0, "Lupus":0 };
            dataToRender.forEach(sub => {
                if(sub.pjd !== null) {
                    if(sub.pjd.infra.includes("Selamat diduduki")) dPJD["Selamat"]++;
                    else if(sub.pjd.infra.includes("Tidak")) dPJD["T.Selamat"]++;
                    else if(sub.pjd.infra.includes("Penyelenggaraan")) dPJD["Selenggara"]++;
                    else dPJD["Lupus"]++;
                }
            });

            if(chart1) chart1.destroy();
            if(chart2) chart2.destroy();

            chart1 = new Chart(document.getElementById('chartFizikal').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: Object.keys(dFizikal),
                    datasets: [{
                        label: 'Jumlah Kriteria',
                        data: Object.values(dFizikal),
                        backgroundColor: ['#6b7280', '#16a34a', '#1e40af', '#ca8a04', '#f97316', '#dc2626']
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });

            chart2 = new Chart(document.getElementById('chartPJD').getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: Object.keys(dPJD),
                    datasets: [{
                        data: Object.values(dPJD),
                        backgroundColor: ['#0d9488', '#ef4444', '#6b7280', '#991b1b']
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false }
            });
        }

