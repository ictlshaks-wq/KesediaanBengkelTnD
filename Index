<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistem Pemantauan Status Bengkel (SPSB)</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Chart.js untuk Dashboard -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- FontAwesome untuk Ikon -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#1e3a8a',
                        secondary: '#3b82f6',
                        accent: '#f59e0b',
                        // Warna khas ikut spesifikasi gambar
                        tblheader: '#d08c38',
                        tblleft: '#fdf6e3',
                        pjdheader: '#425a8f',
                        pjdleft: '#e6f0fa',
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f3f4f6; }
        .fade-in { animation: fadeIn 0.4s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        
        /* Table specific styles for strict borders */
        .form-table td, .form-table th { border: 1px solid #d1d5db; }
        
        /* Hilangkan default file input */
        input[type="file"] { display: none; }
    </style>
</head>
<body class="text-gray-800 h-screen flex flex-col overflow-hidden">

    <!-- Navigation Bar -->
    <nav class="bg-primary text-white shadow-lg z-10 flex-shrink-0">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-20">
                <div class="flex items-center gap-3">
                    <img src="https://raw.githubusercontent.com/ictlshaks-wq/LOGODGURU/main/Logo-Korporat-KPM-BM-Tulisan-Putih.png" alt="Logo KPM" class="h-16 w-auto">
                    <span class="font-bold text-xl tracking-wide hidden md:block">Pemantauan Kesediaan Bengkel RBT dan Makmal Komputer bagi Pelaksanaan MP Teknologi dan Digital</span>
                    <span class="font-bold text-xl tracking-wide md:hidden">SPSB</span>
                </div>
                <div class="flex space-x-2 md:space-x-4">
                    <button onclick="switchPage('form')" id="btn-form" class="bg-secondary bg-opacity-50 hover:bg-opacity-100 text-white px-4 py-2 rounded-md text-sm font-medium transition duration-200 flex items-center gap-2">
                        <i class="fa-solid fa-school"></i> <span class="hidden sm:inline">1. Pengisian Sekolah</span>
                    </button>
                    <button onclick="switchPage('pjd')" id="btn-pjd" class="text-gray-300 hover:bg-secondary hover:text-white px-4 py-2 rounded-md text-sm font-medium transition duration-200 flex items-center gap-2">
                        <i class="fa-solid fa-user-tie"></i> <span class="hidden sm:inline">2. Pengesahan PJD</span>
                    </button>
                    <button onclick="switchPage('dashboard')" id="btn-dashboard" class="text-gray-300 hover:bg-secondary hover:text-white px-4 py-2 rounded-md text-sm font-medium transition duration-200 flex items-center gap-2">
                        <i class="fa-solid fa-chart-pie"></i> <span class="hidden sm:inline">3. Dashboard</span>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content Area -->
    <main class="flex-1 overflow-y-auto p-4 md:p-8 w-full" id="main-container">
        
        <!-- PAGE 1: BORANG PENGISIAN SEKOLAH -->
        <div id="page-form" class="max-w-6xl mx-auto fade-in">
            <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-200">
                
                <form id="bengkelForm" onsubmit="submitFormSekolah(event)" class="p-6 md:p-8">
                    
                    <!-- BAHAGIAN 1: SEKOLAH -->
                    <div class="mb-4">
                        <div class="flex items-center gap-3 mb-6 border-b pb-2">
                            <span class="bg-primary text-white w-8 h-8 rounded-full flex items-center justify-center font-bold">1</span>
                            <h3 class="text-xl font-bold text-gray-700">Bahagian 1: Maklumat Sekolah & Penilaian Bengkel</h3>
                        </div>

                        <!-- Maklumat Asas -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8 bg-gray-50 p-5 rounded-lg border border-gray-200">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Negeri</label>
                                <select id="negeri" required onchange="updateDaerah()" class="w-full border border-gray-300 rounded-md p-2 focus:ring-2 focus:ring-secondary outline-none">
                                    <option value="">-- Pilih Negeri --</option>
                                    <option value="Johor">Johor</option>
                                    <option value="Kedah">Kedah</option>
                                    <option value="Kelantan">Kelantan</option>
                                    <option value="Melaka">Melaka</option>
                                    <option value="Negeri Sembilan">Negeri Sembilan</option>
                                    <option value="Pahang">Pahang</option>
                                    <option value="Perak">Perak</option>
                                    <option value="Perlis">Perlis</option>
                                    <option value="Pulau Pinang">Pulau Pinang</option>
                                    <option value="Sabah">Sabah</option>
                                    <option value="Sarawak">Sarawak</option>
                                    <option value="Selangor">Selangor</option>
                                    <option value="Terengganu">Terengganu</option>
                                    <option value="WP Kuala Lumpur">WP Kuala Lumpur</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Daerah (PPD)</label>
                                <select id="daerah" required class="w-full border border-gray-300 rounded-md p-2 focus:ring-2 focus:ring-secondary outline-none disabled:bg-gray-200">
                                    <option value="">-- Pilih Negeri Dahulu --</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Nama Sekolah</label>
                                <input type="text" id="namaSekolah" required placeholder="Cth: SMK CONTOH PERDANA" class="w-full border border-gray-300 rounded-md p-2 focus:ring-2 focus:ring-secondary outline-none uppercase">
                            </div>
                        </div>
                        
                        <!-- Bekas Untuk Penjanaan 6 Bengkel -->
                        <div id="bengkel-container" class="space-y-10">
                            <!-- Javascript akan jana jadual KEADAAN FIZIKAL di sini -->
                        </div>

                        <!-- Maklumat Pegawai Sekolah Yang Mengisi -->
                        <div class="mt-10 bg-blue-50 p-6 rounded-lg border border-blue-200">
                            <h4 class="font-bold text-gray-800 mb-4 text-sm uppercase tracking-wide border-b border-blue-200 pb-2">Maklumat Pegawai Sekolah (Pengisi Borang)</h4>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-sm font-semibold text-gray-700 mb-2">Nama Pegawai</label>
                                    <input type="text" id="sekolahNamaPegawai" required placeholder="Masukkan nama penuh" class="w-full border border-gray-300 rounded-md p-2 focus:ring-2 focus:ring-secondary outline-none">
                                </div>
                                <div>
                                    <label class="block text-sm font-semibold text-gray-700 mb-2">Jawatan</label>
                                    <input type="text" id="sekolahJawatanPegawai" required placeholder="Cth: Pengetua / Ketua Panitia RBT" class="w-full border border-gray-300 rounded-md p-2 focus:ring-2 focus:ring-secondary outline-none">
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- Butang Hantar Sekolah -->
                    <div class="flex justify-end gap-4 mt-8 pt-6 border-t border-gray-200">
                        <button type="button" onclick="location.reload()" class="px-6 py-2.5 border border-gray-300 text-gray-700 rounded-md font-medium hover:bg-gray-100 transition">Set Semula</button>
                        <button type="submit" class="px-8 py-2.5 bg-primary text-white rounded-md font-medium hover:bg-blue-800 shadow-md transition flex items-center gap-2">
                            <i class="fa-solid fa-paper-plane"></i> Hantar Pengisian Sekolah
                        </button>
                    </div>

                </form>
            </div>
        </div>

        <!-- PAGE 2: PENGESAHAN PJD -->
        <div id="page-pjd" class="max-w-6xl mx-auto hidden fade-in">
            <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-200">
                <div class="p-6 md:p-8">
                    <div class="flex items-center gap-3 mb-6 border-b pb-2">
                        <span class="bg-pjdheader text-white w-8 h-8 rounded-full flex items-center justify-center font-bold">2</span>
                        <h3 class="text-xl font-bold text-gray-700">Bahagian 2: Pengesahan Penolong Jurutera Daerah (PJD)</h3>
                    </div>

                    <!-- Tapis & Maklumat Ringkas PJD -->
                    <div class="mb-6 bg-gray-50 p-5 rounded-lg border border-gray-200">
                        <h4 class="font-bold text-gray-700 mb-3 text-sm uppercase"><i class="fa-solid fa-filter text-secondary mr-2"></i>Tapis Senarai Mengikut Kawasan</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">Negeri</label>
                                <select id="pjdFilterNegeri" onchange="updatePjdFilterDaerah()" class="w-full border border-gray-300 rounded-md p-2 focus:ring-1 focus:ring-blue-500 outline-none text-sm">
                                    <option value="">-- Semua Negeri --</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">Daerah (PPD)</label>
                                <select id="pjdFilterDaerah" onchange="muatSenaraiSekolahPjd()" disabled class="w-full border border-gray-300 rounded-md p-2 focus:ring-1 focus:ring-blue-500 outline-none text-sm disabled:bg-gray-100">
                                    <option value="">-- Semua Daerah --</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Rumusan Status Daerah -->
                    <div id="pjdSummaryBox" class="mb-6 hidden">
                        <div class="bg-yellow-50 border-l-4 border-yellow-500 p-4 rounded-md shadow-sm">
                            <div class="flex items-start">
                                <div class="flex-shrink-0 mt-0.5">
                                    <i class="fa-solid fa-circle-info text-yellow-500"></i>
                                </div>
                                <div class="ml-3">
                                    <h3 class="text-sm font-bold text-yellow-800">Status Kawasan: <span id="pjdSummaryDaerahTxt"></span></h3>
                                    <div class="mt-1 text-sm text-yellow-700" id="pjdSummaryContent">
                                        <!-- Injected via JS -->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Pilih Sekolah Dropdown -->
                    <div class="mb-8 bg-blue-50 p-5 rounded-lg border border-blue-200">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Pilih Sekolah Untuk Disahkan <span class="text-xs font-normal text-gray-500">(Sekolah yang belum disahkan sahaja)</span></label>
                        <select id="pilihSekolahPjd" onchange="paparMaklumatSekolahPjd()" class="w-full border border-gray-300 rounded-md p-3 focus:ring-2 focus:ring-blue-500 outline-none font-medium">
                            <option value="">-- Memuatkan Senarai Sekolah --</option>
                        </select>
                    </div>

                    <!-- Container Paparan Maklumat Sekolah (Read Only) -->
                    <div id="paparanMaklumatSekolah" class="hidden mb-10 border border-gray-200 rounded-lg p-5 bg-gray-50 shadow-sm">
                        <div class="flex justify-between items-center border-b pb-3 mb-4">
                            <h4 class="font-bold text-gray-800 uppercase text-sm"><i class="fa-solid fa-file-contract text-primary mr-2"></i>Dapatan Tapak Pengisian Sekolah</h4>
                            <span class="bg-yellow-100 text-yellow-700 text-xs px-2 py-1 rounded font-bold border border-yellow-200">Menunggu Pengesahan PJD</span>
                        </div>
                        
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6 text-sm bg-white p-4 rounded border border-gray-200">
                            <div><span class="text-gray-500 block text-xs">Nama Sekolah:</span><strong id="paparNamaSekolah" class="text-primary text-base"></strong></div>
                            <div><span class="text-gray-500 block text-xs">Daerah/Negeri:</span><strong id="paparLokasiSekolah"></strong></div>
                            <div><span class="text-gray-500 block text-xs">Pegawai Pengisi:</span><strong id="paparPengisiSekolah"></strong></div>
                            <div><span class="text-gray-500 block text-xs">Tarikh Isi:</span><strong id="paparTarikhSekolah"></strong></div>
                        </div>
                        
                        <div id="paparJadualBengkel" class="space-y-4">
                            <!-- Jadual ringkasan 6 bengkel akan dijana di sini oleh JS -->
                        </div>
                    </div>

                    <!-- Form PJD -->
                    <form id="formPengesahanPjd" onsubmit="submitFormPjd(event)" class="hidden">
                        
                        <div class="overflow-x-auto shadow-sm rounded-t-lg">
                            <table class="w-full text-sm form-table bg-white text-left">
                                <thead>
                                    <tr>
                                        <th colspan="2" class="bg-pjdheader text-white font-bold py-3 text-center uppercase tracking-wide">Borang Pengesahan Pegawai Teknikal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="w-1/4 bg-pjdleft font-bold text-gray-800 p-3 uppercase">Nama Pegawai</td>
                                        <td class="p-2"><input type="text" id="pjdNama" required class="w-full p-2 border border-gray-300 rounded focus:ring-1 focus:ring-blue-500 outline-none" placeholder="Masukkan nama penuh PJD"></td>
                                    </tr>
                                    <tr>
                                        <td class="bg-pjdleft font-bold text-gray-800 p-3 uppercase">No K/P</td>
                                        <td class="p-2"><input type="text" id="pjdKp" required class="w-full p-2 border border-gray-300 rounded focus:ring-1 focus:ring-blue-500 outline-none" placeholder="Contoh: 901212105566"></td>
                                    </tr>
                                    <tr>
                                        <td class="bg-pjdleft font-bold text-gray-800 p-3 uppercase">Jawatan</td>
                                        <td class="p-2"><input type="text" id="pjdJawatan" required class="w-full p-2 border border-gray-300 rounded focus:ring-1 focus:ring-blue-500 outline-none" placeholder="Cth: Penolong Jurutera JA29"></td>
                                    </tr>
                                    <tr>
                                        <td class="bg-pjdleft font-bold text-gray-800 p-3 uppercase">Tarikh Pengesahan</td>
                                        <td class="p-2"><input type="date" id="pjdTarikh" required class="w-full md:w-1/3 p-2 border border-gray-300 rounded focus:ring-1 focus:ring-blue-500 outline-none"></td>
                                    </tr>
                                    
                                    <!-- Status Infrastruktur Options -->
                                    <tr>
                                        <td class="bg-pjdleft font-bold text-gray-800 p-3 uppercase">Status Infrastruktur</td>
                                        <td class="p-2">
                                            <input type="hidden" id="pjdStatusInfra" required>
                                            <div class="grid grid-cols-2 md:grid-cols-4 gap-2" id="group-status-infra">
                                                <button type="button" onclick="selectPjdStatus(this, 'pjdStatusInfra', 'bg-teal-600')" class="btn-pjd border border-gray-300 bg-white text-teal-600 font-semibold py-2 px-2 rounded hover:bg-gray-50 transition" data-val="Selamat diduduki">Selamat diduduki</button>
                                                <button type="button" onclick="selectPjdStatus(this, 'pjdStatusInfra', 'bg-red-600')" class="btn-pjd border border-gray-300 bg-white text-red-600 font-semibold py-2 px-2 rounded hover:bg-gray-50 transition" data-val="Tidak selamat diduduki">Tidak selamat diduduki</button>
                                                <button type="button" onclick="selectPjdStatus(this, 'pjdStatusInfra', 'bg-gray-500')" class="btn-pjd border border-gray-300 bg-white text-gray-600 font-semibold py-2 px-2 rounded hover:bg-gray-50 transition" data-val="Dalam Penyelenggaraan">Dalam Penyelenggaraan</button>
                                                <button type="button" onclick="selectPjdStatus(this, 'pjdStatusInfra', 'bg-red-800')" class="btn-pjd border border-gray-300 bg-white text-red-800 font-semibold py-2 px-2 rounded hover:bg-gray-50 transition" data-val="Lupus">Lupus</button>
                                            </div>
                                        </td>
                                    </tr>

                                    <!-- Skala Options -->
                                    <tr>
                                        <td class="bg-pjdleft font-bold text-gray-800 p-3 uppercase">Skala</td>
                                        <td class="p-2">
                                            <input type="hidden" id="pjdSkala" required>
                                            <div class="grid grid-cols-2 md:grid-cols-7 gap-2" id="group-skala">
                                                <button type="button" onclick="selectPjdStatus(this, 'pjdSkala', 'bg-gray-800')" class="btn-pjd border border-gray-300 bg-white text-gray-800 font-semibold py-2 text-xs rounded hover:bg-gray-50 transition" data-val="Normal">Normal</button>
                                                <button type="button" onclick="selectPjdStatus(this, 'pjdSkala', 'bg-blue-500')" class="btn-pjd border border-gray-300 bg-white text-blue-500 font-semibold py-2 text-xs rounded hover:bg-gray-50 transition" data-val="Selenggara Berjadual">Selenggara Berjadual</button>
                                                <button type="button" onclick="selectPjdStatus(this, 'pjdSkala', 'bg-purple-600')" class="btn-pjd border border-gray-300 bg-white text-purple-600 font-semibold py-2 text-xs rounded hover:bg-gray-50 transition" data-val="Selenggara Korektif">Selenggara Korektif</button>
                                                <button type="button" onclick="selectPjdStatus(this, 'pjdSkala', 'bg-green-500')" class="btn-pjd border border-gray-300 bg-white text-green-500 font-semibold py-2 text-xs rounded hover:bg-gray-50 transition" data-val="Pemulihan">Pemulihan</button>
                                                <button type="button" onclick="selectPjdStatus(this, 'pjdSkala', 'bg-yellow-600')" class="btn-pjd border border-gray-300 bg-white text-yellow-600 font-semibold py-2 text-xs rounded hover:bg-gray-50 transition" data-val="Ubah Suai">Ubah Suai</button>
                                                <button type="button" onclick="selectPjdStatus(this, 'pjdSkala', 'bg-orange-500')" class="btn-pjd border border-gray-300 bg-white text-orange-500 font-semibold py-2 text-xs rounded hover:bg-gray-50 transition" data-val="Naik Taraf">Naik Taraf</button>
                                                <button type="button" onclick="selectPjdStatus(this, 'pjdSkala', 'bg-red-700')" class="btn-pjd border border-gray-300 bg-white text-red-700 font-semibold py-2 text-xs rounded hover:bg-gray-50 transition" data-val="Penggantian/Lupus">Penggantian/Lupus</button>
                                            </div>
                                        </td>
                                    </tr>

                                    <!-- Upload & Textarea -->
                                    <tr>
                                        <td class="bg-pjdleft font-bold text-gray-800 p-3 uppercase">Dokumen JKR</td>
                                        <td class="p-2">
                                            <input type="file" id="file_jkr" onchange="gambarDipilih(this, 'btn_jkr_upload')">
                                            <button type="button" id="btn_jkr_upload" onclick="document.getElementById('file_jkr').click()" class="bg-[#4a5568] hover:bg-gray-700 text-white py-2 px-4 rounded font-semibold text-sm transition flex items-center gap-2 w-max">
                                                <i class="fa-solid fa-file-arrow-up"></i> MUAT NAIK / LIHAT DOKUMEN
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="bg-pjdleft font-bold text-gray-800 p-3 uppercase">Catatan Pengesahan</td>
                                        <td class="p-2"><textarea id="pjdCatatan" rows="3" class="w-full p-2 border border-gray-300 rounded focus:ring-1 focus:ring-blue-500 outline-none" placeholder="Ulasan teknikal..."></textarea></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- Butang Hantar PJD -->
                        <div class="flex justify-end gap-4 mt-6 pt-6 border-t border-gray-200">
                            <button type="submit" class="px-8 py-2.5 bg-green-600 text-white rounded-md font-medium hover:bg-green-700 shadow-md transition flex items-center gap-2">
                                <i class="fa-solid fa-check-double"></i> Hantar Pengesahan PJD
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- PAGE 3: DASHBOARD -->
        <div id="page-dashboard" class="max-w-7xl mx-auto hidden fade-in">
            
            <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
                <div>
                    <h2 class="text-3xl font-bold text-gray-800">Dashboard Pemantauan</h2>
                    <p class="text-gray-500">Ringkasan status fizikal bengkel sekolah menengah.</p>
                </div>
                <button onclick="refreshDashboard()" class="bg-white border border-gray-300 text-gray-600 px-4 py-2 rounded shadow-sm hover:bg-gray-50 transition flex items-center gap-2">
                    <i class="fa-solid fa-rotate-right"></i> Muat Semula
                </button>
            </div>

            <!-- Filter Section -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
                <div class="flex justify-between items-center mb-4 border-b border-gray-100 pb-2">
                    <h3 class="text-lg font-bold text-gray-700 flex items-center gap-2"><i class="fa-solid fa-filter text-secondary"></i> Tapis & Carian Maklumat</h3>
                    <button onclick="resetFilters()" class="text-xs px-3 py-1.5 text-gray-500 border border-gray-300 rounded hover:bg-gray-100 transition"><i class="fa-solid fa-xmark mr-1"></i>Set Semula</button>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Negeri</label>
                        <select id="filterNegeri" onchange="updateFilterDaerah()" class="w-full border border-gray-300 rounded p-2 focus:ring-1 focus:ring-secondary outline-none text-sm">
                            <option value="">Semua Negeri</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Daerah</label>
                        <select id="filterDaerah" onchange="applyFilters()" disabled class="w-full border border-gray-300 rounded p-2 focus:ring-1 focus:ring-secondary outline-none text-sm disabled:bg-gray-100">
                            <option value="">Semua Daerah</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Nama Sekolah</label>
                        <input type="text" id="filterSekolah" onkeyup="applyFilters()" placeholder="Cari nama sekolah..." class="w-full border border-gray-300 rounded p-2 focus:ring-1 focus:ring-secondary outline-none text-sm uppercase">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Status Pengesahan</label>
                        <select id="filterStatus" onchange="applyFilters()" class="w-full border border-gray-300 rounded p-2 focus:ring-1 focus:ring-secondary outline-none text-sm">
                            <option value="">Semua Status</option>
                            <option value="Menunggu PJD">Menunggu Pengesahan PJD</option>
                            <option value="Selamat diduduki">Telah Disahkan: Selamat diduduki</option>
                            <option value="Tidak selamat diduduki">Telah Disahkan: Tidak selamat diduduki</option>
                            <option value="Dalam Penyelenggaraan">Telah Disahkan: Dalam Penyelenggaraan</option>
                            <option value="Lupus">Telah Disahkan: Lupus</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- KPI Cards -->
